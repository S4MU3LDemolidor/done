{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main, quick-add and focus windows",
  "windows": ["main", "quickadd", "focus"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-set-size",
    "core:window:allow-center",
    "core:window:allow-is-visible",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:allow-remove",
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/FocusBar" }, { "path": "$HOME/FocusBar/**" }]
    }
  ]
}
